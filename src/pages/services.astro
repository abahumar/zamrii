---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Services | Zamri Dev"
  description="Custom WooCommerce development, plugin engineering, automation systems, API integrations, and performance optimization services."
>
  <main>
    <section class="page-hero">
      <div class="container reveal">
        <p class="kicker">Services</p>
        <h1>WordPress Systems for Growing Stores</h1>
        <p>I typically work on projects that require custom functionality or system-level improvements.</p>
      </div>
    </section>

    <section class="page-bento">
      <div class="container bento-grid">
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Service</p>
          <h2>Custom WooCommerce Development</h2>
          <p>WooCommerce feature customization including checkout, pricing, shipping, payment, and product logic.</p>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Service</p>
          <h2>WordPress Plugin Development</h2>
          <p>Development of standalone WordPress plugins tailored to internal workflows and custom requirements.</p>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Service</p>
          <h2>WooCommerce Performance Optimization</h2>
          <p>Database query optimization, plugin conflict reduction, and speed improvements for high-volume stores.</p>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Service</p>
          <h2>WooCommerce Automation Systems</h2>
          <p>Automation for order handling workflows using background processing and cron-based jobs.</p>
        </article>

        <article class="bento-card bento-full reveal">
          <p class="bento-label">Service</p>
          <h2>API Integrations</h2>
          <p>Integration with external APIs or services, including payment and operational systems.</p>
        </article>

        <article class="bento-card bento-full bento-cta reveal">
          <p class="bento-label">Contact</p>
          <h2>Need a Custom WooCommerce System?</h2>
          <a class="btn btn-primary" href="/contact/">Discuss Your Project</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
