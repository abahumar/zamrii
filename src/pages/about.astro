---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | Zamri Dev"
  description="WordPress developer focused on building custom WooCommerce systems, automation tools, and integrations for business workflows."
>
  <main>
    <section class="page-hero">
      <div class="container reveal">
        <p class="kicker">About</p>
        <h1>WordPress Developer Focused on WooCommerce Systems</h1>
        <p>I build custom functionality, automation tools, and integrations for operational store challenges.</p>
      </div>
    </section>

    <section class="page-bento">
      <div class="container bento-grid">
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Who I Help</p>
          <h2>Growing Stores That Need More Than Default Plugins</h2>
          <p>
            Most of my work starts when existing plugins are too limited for real operational needs.
            I design and build systems that fit how the business actually works.
          </p>
        </article>

        <article class="bento-card bento-half reveal">
          <p class="bento-label">What I Build</p>
          <ul>
            <li>Custom WooCommerce functionality</li>
            <li>Order automation and workflow systems</li>
            <li>Performance improvements for large catalogs</li>
            <li>Integrations with external tools and APIs</li>
          </ul>
        </article>

        <article class="bento-card bento-full bento-cta reveal">
          <p class="bento-label">Contact</p>
          <h2>Need a WooCommerce System Built Around Your Workflow?</h2>
          <a class="btn btn-primary" href="/contact/">Start a Project</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
