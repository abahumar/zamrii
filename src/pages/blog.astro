---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Blog | Zamri Dev"
  description="Insights on WordPress development, WooCommerce customization, and website performance optimization."
>
  <main>
    <section class="page-hero">
      <div class="container reveal">
        <p class="kicker">Insights & Development Notes</p>
        <h1>WordPress, WooCommerce, and Performance Topics</h1>
        <p>Short, practical notes from real builds.</p>
      </div>
    </section>

    <section class="page-bento">
      <div class="container bento-grid">
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Article</p>
          <h2>How to Customize WooCommerce Checkout Without Slowing Down Your Store</h2>
          <a class="btn btn-ghost" href="#">Read Draft</a>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Article</p>
          <h2>WordPress Plugin vs API Integration: A Simple Decision Guide</h2>
          <a class="btn btn-ghost" href="#">Read Draft</a>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Article</p>
          <h2>How to Speed Up WooCommerce Websites for Better Conversion</h2>
          <a class="btn btn-ghost" href="#">Read Draft</a>
        </article>
        <article class="bento-card bento-half reveal">
          <p class="bento-label">Article</p>
          <h2>Best WordPress Architecture for Growing E-Commerce Teams</h2>
          <a class="btn btn-ghost" href="#">Read Draft</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
